@page "/login"
@using Chat.Client.Services
@using Chat.Shared.Models
@using Chat.Client.Components

@inject NavigationManager NavigationManager
@inject IUserService UserService

<LoginForm OnTryLogin="TryLogin" />

@code {
    [Inject] ILogger<Login> Logger { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {

        UserService.OnUserChanged += HandleUserChanged;

        if (UserService.AuthorizeAutoLogin && await UserService.GetCurrentUserAsync() is not null)
        {
            Logger.LogInformation("[{Name}]User already logged in. Redirecting to home page", nameof(Login));
            NavigationManager.NavigateTo("/");
        }
    }
    private void HandleUserChanged(User? user)
    {
        Logger.LogInformation("[{Name}]User changed ? ", nameof(Login));
        if (user is not null)
        {
            Logger.LogInformation("[{Name}]User changed. New user: {User}. Redirecting to home page", nameof(Login), user);
            NavigationManager.NavigateTo("/");
            return;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task TryLogin(string username)
    {
        Logger.LogInformation("[{Name}]Trying to login with username: {Username}", nameof(Login), username);
        await UserService.LoginAsync(username);

    }


}