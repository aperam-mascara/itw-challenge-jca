

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: calc(100vh - 64px);">
    <MudPaper Elevation="3" Class="pa-8" Style="width: 100%;">
        <MudText Typo="Typo.h5" Class="mb-4 text-center">@Title</MudText>

        <MudText Typo="Typo.body1" Class="mb-4">Enter your username to start chatting:</MudText>

        <MudTextField T="string"
        @bind-Value="Username"
        Label="Username"
        Variant="Variant.Outlined"
        Adornment="Adornment.End"
        AdornmentIcon="@Icons.Material.Filled.Person"
        Class="mb-4"
        Placeholder="Enter a username"
        Required="true"
        RequiredError="Username is required"
        Immediate="true"
        Error="_hasError"
        ErrorText="Username is required"
       />

        <MudButton Variant="Variant.Filled"
        Color="Color.Primary"
        FullWidth="true"
        OnClick="TryLogin"
        
        Disabled="string.IsNullOrWhiteSpace(Username)">
            @ButtonEnterTitle
        </MudButton>
    </MudPaper>
</MudContainer>
@code {

    [Inject] ILogger<LoginForm> Logger { get; set; } = null!;

    [Parameter]
    public EventCallback<string> OnTryLogin { get; set; }


    private string Username { get; set; } = string.Empty;

    [Parameter]
    public string Title { get; set; } = "Welcome to Simple Chat";

    [Parameter]
    public string ButtonEnterTitle { get; set; } = "Enter Chat";

    private bool _hasError;

    private async Task TryLogin()
    {
        if (string.IsNullOrWhiteSpace(Username))
        {

            Logger.LogWarning("[{Name}]Username is empty. Abort Login",nameof(LoginForm));
            _hasError = true;
            return;
        }
        Logger.LogInformation("[{Name}Username is not empty. Proceeding with login", nameof(LoginForm));
        await OnTryLogin.InvokeAsync(Username);
    }

    
}
