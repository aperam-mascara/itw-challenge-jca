@using Chat.Client.Components
@using Chat.Client.Services
@using Chat.Shared.Models
@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6">APERAM - Simple Chat</MudText>
        <MudSpacer />
        @if (_currentUser != null)
        {
            <MudStack Row="true">
                <MudText Class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                    <span>@_currentUser?.Username</span>
                </MudText>

                <MudIconButton Icon="@Icons.Material.Filled.Logout" aria-label="logout" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" OnClick="LogoutAsync" />

            </MudStack>
        }
    </MudAppBar>
    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private User? _currentUser;


    [Inject] private IUserService UserService { get; set; } = null!;
    [Inject] private NavigationManager NavigationManager { get; set; } = null!;




    protected override void OnInitialized()
    {
        UserService.OnUserChanged += HandleUserChanged;

    }




    private void HandleUserChanged(User? user)
    {
        _currentUser = user;
        if (_currentUser == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task LogoutAsync()
    {
        await UserService.LogoutAsync();

    }
}